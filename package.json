{
  "name": "@zolomedia/bifrost-client",
  "version": "1.7.110",
  "description": "Browser client for zBifrost — the WebSocket bridge that turns JSON events from a zOS server into live DOM. Thin bootstrap + server-controlled core.",
  "homepage": "https://github.com/ZoloAi/zbifrost-client#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZoloAi/zbifrost-client.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "bifrost_client.js",
  "files": [
    "bifrost_client.js",
    "bifrost_core.js",
    "L1_Foundation",
    "L2_Handling",
    "L3_Abstraction",
    "L4_Orchestration",
    "zSys",
    "syntax",
    "docs"
  ],
  "keywords": [
    "zos",
    "zbifrost",
    "websocket",
    "ssr",
    "declarative-ui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test",
    "postpublish": "node scripts/postpublish.js",
    "release:patch": "npm test && npm version patch && npm publish && git push && git push --tags"
  },
  "devDependencies": {
    "jsdom": "^24.1.3",
    "vitest": "^2.1.9"
  }
}
